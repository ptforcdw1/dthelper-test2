# Secrets — see docs/secrets-setup.md
# DO NOT COMMIT a populated .env

# Dynatrace
DT_TENANT_URL=https://xxx.live.dynatrace.com
DT_API_TOKEN=__set_me__

# GitHub (used by n8n for PR + commits)
GITHUB_PAT=__set_me__
GITHUB_OWNER=ptforcdw1
GITHUB_REPO=dthelper-test2
GITHUB_DEFAULT_BRANCH=main

# Anthropic (Phase 2+, not used in Phase 1)
ANTHROPIC_API_KEY=__set_me_phase_2__

# Runner
RUNNER_PORT=8080

# n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=__set_me__
